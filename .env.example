# ===========================================
# Jigsaw Control Panel - Environment Variables
# ===========================================
# This file is a reference. The install script (install.sh) generates
# the real .env automatically with secure random values.

# Domain Configuration
# The domain where the Jigsaw panel will be accessible.
# Keycloak will be at auth.<PANEL_DOMAIN> automatically.
PANEL_DOMAIN=panel.example.com
ACME_EMAIL=admin@example.com

# PostgreSQL (shared between Keycloak and Jigsaw)
POSTGRES_USER=jigsaw
POSTGRES_PASSWORD=                          # auto-generated by install.sh

# Keycloak Admin Console (https://auth.<PANEL_DOMAIN>)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=                    # set during install

# Keycloak OIDC Client
# The install script generates this and patches it into the
# Keycloak realm JSON so both sides match automatically.
KEYCLOAK_CLIENT_ID=jigsaw-panel
KEYCLOAK_CLIENT_SECRET=                     # auto-generated by install.sh
KEYCLOAK_CONSOLE_URL=https://auth.panel.example.com

# OAuth2 Proxy (protects Traefik dashboard)
OAUTH2_PROXY_COOKIE_SECRET=                 # auto-generated by install.sh

# Per-site container defaults
SITE_WEB_IMAGE_TEMPLATE=jigsaw-php:{phpVersion}
SITE_DB_IMAGE=mariadb:lts
SITE_SFTP_IMAGE=atmoz/sftp
SITES_BASE_PATH_HOST=/home
SITES_BASE_PATH_PANEL=/host-home

# Optional Docker daemon socket override for host-run development
# Linux/macOS default: /var/run/docker.sock
# Windows Docker Desktop default: //./pipe/docker_engine
# DOCKER_SOCKET_PATH=//./pipe/docker_engine

# Session encryption secret
# Used to encrypt the panel's session cookies.
SESSION_SECRET=                             # auto-generated by install.sh
