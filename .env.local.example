# Local development environment (Windows/macOS/Linux)

NODE_ENV=development

# App URL for callback generation
PANEL_URL=http://localhost:5173

# Local PostgreSQL
DATABASE_URL=postgres://jigsaw:jigsaw_secret@localhost:5432/jigsaw

# Local Keycloak (from docker-compose.dev.yml)
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/jigsaw
KEYCLOAK_PUBLIC_URL=http://localhost:8080/realms/jigsaw
KEYCLOAK_CLIENT_ID=jigsaw-panel
KEYCLOAK_CLIENT_SECRET=dev-jigsaw-client-secret
KEYCLOAK_CONSOLE_URL=http://localhost:8080

# Session cookie signing key
SESSION_SECRET=dev-session-secret-change-me

# Docker access (host-run app)
# Windows default for Docker Desktop npipe:
# DOCKER_SOCKET_PATH=//./pipe/docker_engine

# Site service images
SITE_WEB_IMAGE_TEMPLATE=jigsaw-php:{phpVersion}
SITE_DB_IMAGE=mariadb:lts
SITE_SFTP_IMAGE=atmoz/sftp

# Local site paths for development
SITES_BASE_PATH_HOST=./data/local-home
SITES_BASE_PATH_PANEL=./data/local-home

# Optional: set if you want Traefik link in sidebar during local dev
# TRAEFIK_DASHBOARD_URL=http://localhost:8081/dashboard/
